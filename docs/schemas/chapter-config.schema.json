{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vidchopper.dev/schemas/chapter-config.schema.json",
  "title": "VidChopper CLI chapter configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["chapters"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "folder": {
          "type": "string",
          "minLength": 1
        },
        "namingPattern": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "encoder": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "crf": {
          "type": "integer",
          "minimum": 0,
          "maximum": 51
        },
        "cq": {
          "type": "integer",
          "minimum": 0,
          "maximum": 51
        },
        "preset": {
          "type": "string",
          "minLength": 1
        },
        "threads": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        }
      }
    },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "start", "end"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "start": {
            "$ref": "#/$defs/timecode"
          },
          "end": {
            "$ref": "#/$defs/timecode"
          },
          "outputName": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "timecode": {
      "type": "string",
      "pattern": "^([0-9]+:)?[0-5]?[0-9]:[0-5][0-9](\\.[0-9]{1,3})?$",
      "description": "MM:SS, MM:SS.mmm, HH:MM:SS, or HH:MM:SS.mmm. Timeline ordering is validated by the loader."
    }
  }
}
